"""Radiogenomics end-to-end pipeline.

Orchestrates the full flow from public data to a held-out test number:

    download_knijnenburg
        -> manifest                   (TCGA-OV x TCIA join, ~135 patients)
            -> preprocess_all         (CT -> 96^3 NumPy cube per patient)
                -> split_holdout_test (108 dev + 27 test, stratified split)
                    -> train_cv       (5-fold CV on the 108-patient dev set)
                        -> eval_test  (ensemble of all 5 folds, scored
                                       ONCE on the 27-patient test split)

The 27 test patients are isolated before training touches anything, so
the eval_test rule produces a true held-out test AUROC, not a validation
AUROC. Every patient is used somewhere; no waste.
"""

from pathlib import Path

configfile: "pipelines/config.yaml"

DATA = Path(config.get("data_dir", "data"))
MODEL = Path(config.get("model_dir", "models/radiogen_v0"))


rule all:
    input:
        MODEL / "cv_summary.json",
        DATA / "test_eval.json",
        DATA / "radiomics_test_eval.json",


rule download_knijnenburg:
    """Fetch the Knijnenburg 2018 HRD-label supplementary table."""
    output:
        table = DATA / "raw" / "knijnenburg_2018_tableS2.tsv",
    script:
        "scripts/download_knijnenburg.py"


rule manifest:
    """Join TCGA-OV HRD labels with TCIA CT series into one manifest."""
    input:
        hrd = DATA / "raw" / "knijnenburg_2018_tableS2.tsv",
    output:
        manifest = DATA / "manifest.parquet",
    script:
        "scripts/build_manifest.py"


rule preprocess_all:
    """Download + preprocess each CT series to the target 96^3 volume."""
    input:
        manifest = DATA / "manifest.parquet",
    output:
        cache = DATA / "preprocessed" / ".done",
    script:
        "scripts/preprocess_all.py"


rule split_holdout_test:
    """Carve the 27-patient held-out test split off the manifest.

    Stratified on (HRD class x scanner manufacturer). Random seed locked.
    The dev manifest (108) feeds train_cv; the test manifest (27) is
    touched only by eval_test."""
    input:
        manifest = DATA / "manifest.parquet",
    output:
        dev = DATA / "manifest_dev.parquet",
        test = DATA / "manifest_test.parquet",
    script:
        "scripts/split_holdout_test.py"


rule train_cv:
    """5-fold stratified CV training on the 108-patient dev set.

    Reads manifest_dev.parquet (NOT the full manifest) so the test split
    is genuinely never seen during training, hyperparameter tuning, or
    early stopping.
    """
    input:
        manifest = DATA / "manifest_dev.parquet",
        cache = DATA / "preprocessed" / ".done",
    output:
        summary = MODEL / "cv_summary.json",
    params:
        backbone = config.get("backbone", "monai_densenet"),
        epochs = config.get("epochs", 50),
        batch_size = config.get("batch_size", 4),
        lr = config.get("learning_rate", 1.0e-4),
    shell:
        # manifest is positional in the Typer CLI; the rest are --options.
        """
        python -m radiogenomics.train \
            {input.manifest} \
            --backbone {params.backbone} \
            --output {MODEL} \
            --epochs {params.epochs} \
            --batch-size {params.batch_size} \
            --lr {params.lr}
        """


rule eval_test:
    """Score the 5-fold ensemble on the held-out test split exactly once.

    This is what produces the defensible test-set AUROC. Each test patient
    gets a probability from every fold model; the ensemble is the mean of
    those 5 sigmoid outputs. AUROC + AUPRC + per-patient predictions land
    in data/test_eval.json."""
    input:
        summary = MODEL / "cv_summary.json",
        test_manifest = DATA / "manifest_test.parquet",
    output:
        report = DATA / "test_eval.json",
    script:
        "scripts/eval_test.py"


# ---------------------------------------------------------------------------
# Classical-radiomics arm — re-implements Pan et al. 2024 (Front Oncol) on
# the same TCGA-OV cohort and held-out split as the deep model so the two
# approaches are directly comparable.
# ---------------------------------------------------------------------------

rule radiomics_features:
    """Extract PyRadiomics features (intratumoral + peritumoral, ~1500 each)
    for every preprocessed volume.

    Foreground threshold + 3-voxel binary dilation produces the two regions.
    Output is one parquet row per patient with all features as columns."""
    input:
        manifest = DATA / "manifest.parquet",
        cache = DATA / "preprocessed" / ".done",
    output:
        features = DATA / "radiomics_features.parquet",
    script:
        "scripts/extract_radiomics_features.py"


rule clinical_features:
    """Pull TCGA-OV clinical metadata (age, FIGO stage, tumor grade) from
    GDC for every patient in the manifest. Adds the same kind of clinical
    context Pan et al. 2024 fused into their LASSO."""
    input:
        manifest = DATA / "manifest.parquet",
    output:
        clinical = DATA / "clinical_features.parquet",
    script:
        "scripts/download_clinical_features.py"


rule train_radiomics:
    """LASSO logistic-regression classifier on the dev split (108 patients).

    Mann-Whitney univariate filter -> LogisticRegressionCV (l1, saga,
    5-fold internal CV to pick alpha) -> refit on all dev patients.
    Imaging features (intratumoral + peritumoral) get fused with clinical
    features (age, FIGO stage, grade) as candidate features for the LASSO.
    Persists the fitted scaler + selected feature names + model."""
    input:
        features = DATA / "radiomics_features.parquet",
        clinical = DATA / "clinical_features.parquet",
        dev_manifest = DATA / "manifest_dev.parquet",
    output:
        model = MODEL / "radiomics_lasso.pkl",
        summary = MODEL / "radiomics_train_summary.json",
    script:
        "scripts/train_radiomics.py"


rule eval_radiomics_test:
    """Score the trained LASSO model on the 27-patient held-out test split.

    Same patients as the deep model's eval_test rule, so the two test
    AUROCs are apples-to-apples comparable."""
    input:
        features = DATA / "radiomics_features.parquet",
        clinical = DATA / "clinical_features.parquet",
        test_manifest = DATA / "manifest_test.parquet",
        model = MODEL / "radiomics_lasso.pkl",
    output:
        report = DATA / "radiomics_test_eval.json",
    script:
        "scripts/eval_radiomics_test.py"
